{
  "name": "gray-zone-intel-board",
  "version": "1.0.11",
  "version": "1.0.14",
  "description": "Gray Zone Intel Board desktop app",
  "main": "electron/main.js",
  "author": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win dir",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis && npm run clean:release",
    "publish:github": "electron-builder --win nsis --publish always && npm run clean:release",
    "clean:release": "node scripts/clean-release.js"
  },
  "build": {
    "appId": "com.grayzone.intelboard",
    "productName": "Gray Zone Intel Board",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "assets/**/*",
      "*.html",
      "*.js",
      "*.css",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ZCreation",
        "repo": "GrayZoneWarfare-Compaion"
      }
    ],
    "portable": {
      "artifactName": "GrayZoneIntelBoard-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "artifactName": "GrayZoneIntelBoard-Setup-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
